---
import type { CollectionEntry } from "astro:content";
import LoadMoreList from "./LoadMoreList.astro";
import type { Locale } from "../utils/i18n";

interface Props {
  papers: CollectionEntry<"papers">[];
  locale: Locale;
  pageSize?: number;
}

const { papers, locale, pageSize = 5 } = Astro.props;

const CATEGORY_ORDER = ["journal", "conference", "preprint", "workshop", "poster"] as const;

const CATEGORY_LABELS: Record<(typeof CATEGORY_ORDER)[number], Record<Locale, string>> = {
  journal: { ja: "査読付き論文", en: "Journal Articles" },
  conference: { ja: "国際会議・国内会議", en: "Conference Papers" },
  preprint: { ja: "プレプリント", en: "Preprints" },
  workshop: { ja: "ワークショップ論文", en: "Workshop Papers" },
  poster: { ja: "ポスター・発表", en: "Posters / Presentations" },
};

const grouped = CATEGORY_ORDER.map((category) => ({
  category,
  label: CATEGORY_LABELS[category][locale],
  items: papers
    .filter((p) => p.data.category === category)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
})).filter((group) => group.items.length > 0);
---

{
  grouped.map((group) => (
    <div class="paper-group">
      <p class="paper-category">{group.label}</p>
      <LoadMoreList itemCount={group.items.length} locale={locale} pageSize={pageSize}>
        <ul class="entry-list">
          {group.items.map((entry, i) => {
            const data = entry.data;
            const hasLinks =
              data.links.pdf || data.links.code || data.links.project || data.links.bibtex || data.doi || data.arxivId;
            return (
              <li hidden={i >= pageSize}>
                <p class="entry-meta">
                  {data.year} · {data.venue[locale]}
                </p>
                <h3 class="entry-title">{data.title[locale]}</h3>
                <p class="paper-authors">
                  {data.authors.map((author, i) => (
                    <>
                      {i > 0 && ", "}
                      <span class={author.isSelf ? "self" : ""}>{author.name}</span>
                    </>
                  ))}
                </p>
                {data.description?.[locale] && <p class="entry-desc">{data.description[locale]}</p>}
                {hasLinks && (
                  <div class="entry-links">
                    {data.links.pdf && <a href={data.links.pdf}>PDF</a>}
                    {data.links.code && <a href={data.links.code}>Code</a>}
                    {data.links.project && <a href={data.links.project}>Project</a>}
                    {data.links.bibtex && <a href={data.links.bibtex}>BibTeX</a>}
                    {data.doi && <a href={`https://doi.org/${data.doi}`}>DOI: {data.doi}</a>}
                    {data.arxivId && <a href={`https://arxiv.org/abs/${data.arxivId}`}>arXiv:{data.arxivId}</a>}
                  </div>
                )}
              </li>
            );
          })}
        </ul>
      </LoadMoreList>
    </div>
  ))
}

<style>
  .paper-group + .paper-group {
    margin-top: 48px;
  }
</style>
