---
import type { CollectionEntry } from "astro:content";
import LoadMoreList from "./LoadMoreList.astro";
import type { Locale } from "../utils/i18n";

interface Props {
  awards: CollectionEntry<"awards">[];
  locale: Locale;
  pageSize?: number;
}

const { awards, locale, pageSize = 5 } = Astro.props;
const sorted = [...awards].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<LoadMoreList itemCount={sorted.length} locale={locale} pageSize={pageSize}>
  <ul class="entry-list">
    {
      sorted.map((entry, i) => {
        const data = entry.data;
        return (
          <li hidden={i >= pageSize}>
            <p class="entry-meta">{data.year}</p>
            <h3 class="entry-title">{data.url ? <a href={data.url}>{data.title[locale]}</a> : data.title[locale]}</h3>
            <p class="award-org">{data.organization[locale]}</p>
            {data.description?.[locale] && <p class="award-desc">{data.description[locale]}</p>}
          </li>
        );
      })
    }
  </ul>
</LoadMoreList>
