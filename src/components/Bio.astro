---
import { getBio, getLinks } from "../utils/profile";
import type { Locale } from "../utils/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const bio = getBio()[locale];
const links = getLinks();
---

{
  bio.length > 0 && (
    <section id="bio">
      <div class="container">
        <p class="eyebrow">Bio</p>
        <ul class="bio-list">
          {bio.map((line) => (
            <li>{line}</li>
          ))}
        </ul>
        {links.linkedin.url && (
          <p class="view-all">
            <a href={links.linkedin.url}>more →</a>
          </p>
        )}
      </div>
    </section>
  )
}
