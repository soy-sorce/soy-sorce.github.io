---
import { getAlternatePath, getOtherLocale, type Locale } from "../utils/i18n";

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;
const otherLocale = getOtherLocale(locale);
const href = getAlternatePath(pathname, otherLocale);
---

<div class="lang-toggle">
  <span class="lang-current" aria-current="true">{locale.toUpperCase()}</span>
  <span class="lang-sep" aria-hidden="true">/</span>
  <a class="lang-other" href={href}>{otherLocale.toUpperCase()}</a>
</div>

<style>
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 6px 12px;
  }

  .lang-current {
    color: var(--color-text);
  }

  .lang-sep {
    color: var(--color-border);
  }

  .lang-other {
    color: var(--color-muted);
    text-decoration: none;
  }

  .lang-other:hover {
    color: var(--color-accent);
  }
</style>
