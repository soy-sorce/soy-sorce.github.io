---
import type { CollectionEntry } from "astro:content";
import { getArticleHref, isExternalArticle } from "../utils/articles";
import type { Locale } from "../utils/i18n";

interface Props {
  entry: CollectionEntry<"articles">;
  locale: Locale;
  hidden?: boolean;
}

const { entry, locale, hidden = false } = Astro.props;
const href = getArticleHref(entry, locale);
const external = isExternalArticle(entry);
const dateLabel = entry.data.date.toISOString().slice(0, 10);
---

<li hidden={hidden}>
  <p class="entry-meta">
    {entry.data.pinned && <span class="pin-badge">PICK UP</span>}
    {dateLabel}
  </p>
  <h3 class="entry-title">
    {
      external ? (
        <a href={href} target="_blank" rel="noopener noreferrer">
          {entry.data.title} ↗
        </a>
      ) : (
        <a href={href}>{entry.data.title}</a>
      )
    }
  </h3>
  {entry.data.description && <p class="entry-desc">{entry.data.description}</p>}
</li>
