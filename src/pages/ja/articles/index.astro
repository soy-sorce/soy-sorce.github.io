---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArticleEntry from "../../../components/ArticleEntry.astro";
import { getArticlesByLocale } from "../../../utils/articles";

const locale = "ja" as const;
const articles = (await getArticlesByLocale(locale)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout locale={locale} title="Articles - Shohei Ichioka">
  <section id="articles-index">
    <div class="container">
      <p class="eyebrow">Articles</p>
      {
        articles.length > 0 ? (
          <ul class="entry-list">
            {articles.map((entry) => (
              <ArticleEntry entry={entry} locale={locale} />
            ))}
          </ul>
        ) : (
          <p class="empty-state">まだ記事がありません。</p>
        )
      }
    </div>
  </section>
</BaseLayout>
