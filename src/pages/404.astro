---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout locale="ja" title="Page Not Found / ページが見つかりません" hasAlternate={false}>
  <section id="not-found">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>Page Not Found</h1>
      <p>お探しのページは見つかりませんでした。 / The page you are looking for could not be found.</p>
      <div class="link-row">
        <a href="/ja/">日本語トップへ</a>
        <span class="sep" aria-hidden="true">/</span>
        <a href="/en/">English Top</a>
      </div>
    </div>
  </section>
</BaseLayout>
