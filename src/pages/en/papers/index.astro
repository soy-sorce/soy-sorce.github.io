---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PaperList from "../../../components/PaperList.astro";

const locale = "en" as const;
const papers = await getCollection("papers");
---

<BaseLayout locale={locale} title="Papers - Shohei Ichioka">
  <section id="papers-index">
    <div class="container">
      <p class="eyebrow">Papers</p>
      {papers.length > 0 ? <PaperList papers={papers} locale={locale} /> : <p class="empty-state">No papers yet.</p>}
    </div>
  </section>
</BaseLayout>
