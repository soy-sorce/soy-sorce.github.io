---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArticleList from "../../../components/ArticleList.astro";
import { getArticlesByLocale, sortArticles } from "../../../utils/articles";

const locale = "en" as const;
const articles = sortArticles(await getArticlesByLocale(locale));
---

<BaseLayout locale={locale} title="Articles - Shohei Ichioka">
  <section id="articles-index">
    <div class="container">
      <p class="eyebrow">Articles</p>
      {
        articles.length > 0 ? (
          <ArticleList articles={articles} locale={locale} />
        ) : (
          <p class="empty-state">No articles yet.</p>
        )
      }
    </div>
  </section>
</BaseLayout>
